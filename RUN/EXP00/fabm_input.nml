   rfac=71.4 ! 1000./14.0067 (g/s -> mmol/s)
/
&riverdata
   name='DON_ban_n'
   sn=         'river.nc',-1,'DON_ban', .true.,  .true.,   'yearly',     '',         '',        ''
   rfac=64.25 ! 0.9*1000./14.0067 (g/s -> mmol/s)
/
&riverdata
   name='DIN_sri_n'
   sn=         'river.nc',-1,'DIN_sri', .true.,  .true.,   'yearly',     '',         '',        ''
   rfac=71.4 ! 1000./14.0067 (g/s -> mmol/s)
/
&riverdata
   name='DON_sri_n'
   sn=         'river.nc',-1,'DON_sri', .true.,  .true.,   'yearly',     '',         '',        ''
   rfac=64.25 ! 0.9*1000./14.0067 (g/s -> mmol/s)
/
&riverdata
   name='DIN_pak_n'
   sn=         'river.nc',-1,'DIN_pak', .true.,  .true.,   'yearly',     '',         '',        ''
